# Channel credentials (each agent has its own bot)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-bot-token
# For multi-agent:
# TELEGRAM_BOT_TOKEN_CODER=123456:ABC-coder-bot-token
# TELEGRAM_BOT_TOKEN_REVIEWER=789012:DEF-reviewer-bot-token

# GitHub PAT (injected by gateway auth provider)
GITHUB_PAT_TOKEN=ghp_your-github-pat

# MCP OAuth (used by /oauth command flow)
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret

# MCP Token (app credentials)
SLACK_APP_ID=your-slack-app-id
SLACK_APP_SECRET=your-slack-app-secret

# Generic API keys
DD_API_KEY=your-datadog-api-key
